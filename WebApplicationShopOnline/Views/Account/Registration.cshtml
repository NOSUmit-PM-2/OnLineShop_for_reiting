@model WebApplicationShopOnline.Models.Registration

<div class="text-left">
    <h1 class="display-4">Регистрация пользователя</h1>
    <form asp-action="Registration" asp-controller="Account">
        <div class="form-group">
            <label asp-for="UserName">Имя пользователя</label>
            <input asp-for="UserName" class="form-control" placeholder="Введите имя пользователя">
        </div>
        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Введите почту">
        </div>
        <div class="form-group">
            <label asp-for="Password">Пароль</label>
            <input asp-for="Password" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary">Зарегистрировать</button>
    </form>
</div>