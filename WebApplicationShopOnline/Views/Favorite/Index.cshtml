@model List<WebApplicationShopOnline.Models.Product>

@{
    ViewData["Title"] = "Избранное";
}

<h2>⭐ Мои избранные товары</h2>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info">
        У вас пока нет избранных товаров. <a asp-controller="Product" asp-action="Catalog">Перейти в каталог</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card shadow-sm">
                    <img src="@product.PathPicture" class="card-img-top" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h4>@product.Name</h4>
                        <p class="card-text">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group">
                                <a class="btn btn-primary" asp-controller="Product" asp-action="Index" asp-route-id="@product.Id">Подробнее</a>
                                <form asp-controller="Favorite" asp-action="Remove" method="post" style="display: inline;">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn btn-danger">🗑️ Удалить</button>
                                </form>
                            </div>
                            <small class="text-muted">@product.Cost р.</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}