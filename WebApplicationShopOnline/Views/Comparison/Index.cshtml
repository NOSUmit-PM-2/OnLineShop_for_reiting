@model List<Product>

@{
    ViewData["Title"] = "Сравнение товаров";
}

<h2>Сравнение двух последних добавленных товаров</h2>

@if (Model.Count == 0)
{
    <p>Вы ещё не добавили ни одного товара для сравнения.</p>
}
else if (Model.Count == 1)
{
    <p>Добавьте ещё один товар, чтобы сравнить.</p>
    <h4>Товар для сравнения:</h4>
    <div class="card" style="width: 18rem;">
        <img src="@Model[0].PathPicture" class="card-img-top">
        <div class="card-body">
            <h5 class="card-title">@Model[0].Name</h5>
            <p class="card-text">@Model[0].Description</p>
            <p><strong>Цена:</strong> @Model[0].Cost р.</p>
        </div>
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Характеристика</th>
                <th>@Model[0].Name</th>
                <th>@Model[1].Name</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Изображение</td>
                <td><img src="@Model[0].PathPicture" style="max-width:150px" /></td>
                <td><img src="@Model[1].PathPicture" style="max-width:150px" /></td>
            </tr>
            <tr>
                <td>Цена</td>
                <td>@Model[0].Cost р.</td>
                <td>@Model[1].Cost р.</td>
            </tr>
            <tr>
                <td>Описание</td>
                <td>@Model[0].Description</td>
                <td>@Model[1].Description</td>
            </tr>
        </tbody>
    </table>

    <div class="mt-3">
        <a class="btn btn-danger" asp-action="Remove" asp-route-id="@Model[0].Id">Удалить @Model[0].Name</a>
        <a class="btn btn-danger" asp-action="Remove" asp-route-id="@Model[1].Id">Удалить @Model[1].Name</a>
    </div>
}