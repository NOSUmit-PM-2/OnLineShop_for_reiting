@model List<Product>

<h2>Товары для сравнения</h2>

@if (Model.Count == 0)
{
    <p>Список сравнения пуст.</p>
}
else
{
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4">
                <div class="card mb-3">
                    <img src="@product.PathPicture" class="card-img-top" style="max-height: 200px; object-fit: contain;">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Cost р.</p>
                        <a class="btn btn-danger" asp-controller="Comparison" asp-action="Remove" asp-route-id="@product.Id">Удалить</a>
                    </div>
                </div>
            </div>
        }
    </div>
}