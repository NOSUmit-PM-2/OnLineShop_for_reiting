@model List<Product>

<h2>Каталог</h2>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">

    @foreach (var product in Model)
    {
        <div class="col">
            <div class="card shadow-sm">
                <img src="@product.PathPicture" style="height: 200px; object-fit: cover;">

                <div class="card-body">
                    <h4>@product.Name</h4>
                    <p>@product.Id</p>
                    <p class="card-text">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a class="btn btn-primary"
                               asp-controller="Product"
                               asp-action="Index"
                               asp-route-id="@product.Id">Подробнее</a>
                            <a class="btn btn-success"
                               asp-controller="Cart"
                               asp-action="Add"
                               asp-route-id="@product.Id">В корзину</a>

                            <form asp-controller="Favorite" asp-action="Add" method="post" style="display: inline;">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit" class="btn btn-warning">❤️ В избранное</button>
                            </form>
                        </div>
                        <small class="text-muted">@product.Cost р.</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>