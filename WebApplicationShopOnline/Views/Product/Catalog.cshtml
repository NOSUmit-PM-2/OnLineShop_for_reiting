@model List<WebApplicationShopOnline.Models.Product>

<h2>Каталог товаров</h2>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <img src="@product.PathPicture" class="card-img-top" style="height: 150px; object-fit: cover;" />
                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text">@product.Description</p>
                    <p class="card-text"><strong>@product.Cost руб.</strong></p>
                    <a href="@Url.Action("AddToCompare", "Product", new { id = product.Id })" class="btn btn-success w-100">В сравнение</a>
                </div>
            </div>
        </div>
    }
</div>