@model List<Product>

<h2>Каталог</h2>

<form method="get" asp-controller="Product" asp-action="Catalog">
    <div style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
               style="flex: 1; padding: 8px; font-size: 16px;"
               placeholder="Введите название товара..." />
        <button type="submit" style="padding: 8px 16px; font-size: 16px; cursor: pointer;">Поиск</button>
        <a asp-action="Catalog" style="padding: 8px 16px; font-size: 16px; text-decoration: none; background-color: #6c757d; color: white; border-radius: 4px;">Сбросить</a>
    </div>
</form>

<hr />

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
    @if (Model == null || !Model.Any())
    {
        <p>Товары не найдены.</p>
    }
    else
    {
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card shadow-sm">
                    <img src="@product.PathPicture" style="max-width: 100%; height: auto;">
                    <div class="card-body">
                        <h4>@product.Name</h4>
                        <p class="card-text">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group">
                                <a class="btn btn-primary"
                                   asp-area=""
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-id="@product.Id"
                                   role="button">Подробнее</a>
                                <a class="btn btn-primary"
                                   asp-area=""
                                   asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@product.Id"
                                   role="button">В корзину</a>
                            </div>
                            <small class="text-muted">@product.Cost р.</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>