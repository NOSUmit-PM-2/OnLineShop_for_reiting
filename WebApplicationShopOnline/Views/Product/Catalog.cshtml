@model List<Product>

@{
    var currentCategory = ViewBag.CurrentCategory as string ?? "Все товары";
}

<h2>Каталог</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <label for="categoryFilter" class="form-label fw-bold">Фильтр по категории:</label>
        <select id="categoryFilter" class="form-select">
            <option value="">Все товары</option>
            <option value="HOME">Для дома</option>
            <option value="ELECTRIC">Электроника</option>
            <option value="SPORT">Спорт</option>
        </select>
    </div>
    <div class="col-md-8">
        <div class="mt-4">
            <span class="badge bg-primary fs-6">Текущая категория: @currentCategory</span>
            @if (currentCategory != "Все товары")
            {
                <a asp-controller="Product" asp-action="Catalog" class="btn btn-outline-secondary btn-sm ms-2">Сбросить</a>
            }
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
    @foreach(var product in Model)
    {
        <div class="col">
            <div class="card shadow-sm">
                <img src="@product.PathPicture" class="card-img-top" style="height: 200px; object-fit: cover;">

                <div class="card-body">
                    <h4>@product.Name</h4>
                    <p>ID: @product.Id.ToString().Substring(0,8)</p>
                    <p class="card-text">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a class="btn btn-primary"
                               asp-area=""
                               asp-controller="Product"
                               asp-action="Index" 
                               asp-route-id="@product.Id"
                               role="button">Подробнее</a>
                            <a class="btn btn-primary"
                               asp-area=""
                               asp-controller="Cart"
                               asp-action="Add"
                               asp-route-id="@product.Id"
                               role="button">В корзину</a>
                        </div>
                        <small class="text-muted">@product.Cost р.</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const currentCat = urlParams.get('category');
        if (currentCat) {
            const filterSelect = document.getElementById('categoryFilter');
            if (filterSelect) {
                filterSelect.value = currentCat;
            }
        }
        
        document.getElementById('categoryFilter').addEventListener('change', function() {
            const category = this.value;
            let url = '@Url.Action("Catalog", "Product")';
            if (category) {
                url += '?category=' + category;
            }
            window.location.href = url;
        });
    </script>
}