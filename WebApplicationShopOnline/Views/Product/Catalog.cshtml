@model List<Product>

    <h2>Каталог</h2>

<div class="row mb-4">
    <div class="col-md-12">
        <form method="get" asp-action="Catalog" asp-controller="Product" class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Цена от:</label>
                <input type="number" name="minPrice" class="form-control" placeholder="0" value="@Context.Request.Query["minPrice"]" step="any" />
            </div>
            <div class="col-auto">
                <label class="form-label">Цена до:</label>
                <input type="number" name="maxPrice" class="form-control" placeholder="999999" value="@Context.Request.Query["maxPrice"]" step="any" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Поиск</button>
            </div>
            <div class="col-auto">
                <a asp-action="Catalog" class="btn btn-secondary">Сбросить</a>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
     @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">Товары не найдены</div>
        </div>
    }
    else
    {
    @foreach(var product in Model)
    {
        <div class="col">
            <div class="card shadow-sm">
                    <img src="@product.PathPicture">

                <div class="card-body">
                        <h4>@product.Name</h4>
                        <p>@product.Id</p>
                        <p class="card-text">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a class="btn btn-primary"
                               asp-area=""
                               asp-controller="Product"
                               asp-action="Index" 
                               asp-route-id="@product.Id"
                               role="button">Подробнее</a>
                            <a class="btn btn-primary"
                               asp-area=""
                               asp-controller="Cart"
                               asp-action="Add"
                               asp-route-id="@product.Id"
                               role="button">В корзину</a>
                         
                        </div>
                            <small class="text-muted">@product.Cost р.</small>
                    </div>
                </div>
            </div>
        </div>
    }}
</div>
 