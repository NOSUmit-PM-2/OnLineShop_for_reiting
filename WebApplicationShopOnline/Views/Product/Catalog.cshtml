@model List<Product>

@{
    decimal? currentMaxPrice = ViewBag.MaxPrice as decimal?;
}

<h2>Каталог</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <form asp-action="Catalog" asp-controller="Product" method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <label for="maxPrice" class="col-form-label">Максимальная цена:</label>
            </div>
            <div class="col-auto">
                <input type="number"
                       name="maxPrice"
                       id="maxPrice"
                       class="form-control"
                       placeholder="Введите сумму"
                       value="@currentMaxPrice"
                       min="0"
                       step="1">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Поиск</button>
            </div>
            <div class="col-auto">
                <a asp-action="Catalog" class="btn btn-secondary">Сбросить</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info" role="alert">
        @if (currentMaxPrice.HasValue && currentMaxPrice.Value > 0)
        {
            <span>Нет товаров с ценой ниже @currentMaxPrice.Value р.</span>
        }
        else
        {
            <span>В каталоге пока нет товаров.</span>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card shadow-sm">
                    <img src="@product.PathPicture" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;">

                    <div class="card-body">
                        <h4>@product.Name</h4>
                        <p class="card-text">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group">
                                <a class="btn btn-primary"
                                   asp-area=""
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-id="@product.Id"
                                   role="button">Подробнее</a>
                                <a class="btn btn-primary"
                                   asp-area=""
                                   asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@product.Id"
                                   role="button">В корзину</a>
                            </div>
                            <small class="text-muted">@product.Cost р.</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}