@model List<Product>

<h2>Сравнение товаров</h2>

@if (Model.Count == 0)
{
    <p>Нет товаров для сравнения. Добавьте товары из каталога.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th></th>
                @foreach (var product in Model)
                {
                    <th>@product.Name</th>
                }
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong>Изображение</strong></td>
                @foreach (var product in Model)
                {
                    <td><img src="@product.PathPicture" alt="@product.Name" style="max-width: 200px;"></td>
                }
            </tr>
            <tr>
                <td><strong>Описание</strong></td>
                @foreach (var product in Model)
                {
                    <td>@product.Description</td>
                }
            </tr>
            <tr>
                <td><strong>Цена</strong></td>
                @foreach (var product in Model)
                {
                    <td>@product.Cost р.</td>
                }
            </tr>
        </tbody>
    </table>

    <div class="mt-3">
        @foreach (var product in Model)
        {
            <a class="btn btn-primary me-2"
               asp-controller="Product"
               asp-action="Index"
               asp-route-id="@product.Id">
                Подробнее (@product.Name)
            </a>
            <a class="btn btn-success me-2"
               asp-controller="Cart"
               asp-action="Add"
               asp-route-id="@product.Id">
                В корзину (@product.Name)
            </a>
        }
    </div>
}
